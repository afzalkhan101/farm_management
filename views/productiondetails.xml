<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <menuitem id="menu_farm_production_root" name="Production"  parent="menu_layer_flock_root" sequence="30"/>

    <record id="action_farm_production_details" model="ir.actions.act_window">
        <field name="name">Production Details</field>
        <field name="res_model">farm.production.details</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Record daily egg production here.
            </p>
        </field>
    </record>

    <menuitem id="menu_farm_production_details" name="Production Records" parent="menu_farm_production_root" action="action_farm_production_details" sequence="1"/>

    <record id="view_farm_production_details_tree" model="ir.ui.view">
        <field name="name">farm.production.details.list</field>
        <field name="model">farm.production.details</field>
        <field name="arch" type="xml">
            <list string="Production Details" default_order="date desc">
                <field name="date"/>
                <field name="flock_id"/>
                <field name="total_hens"/>
                <field name="total_small"/>
                <field name="total_medium"/>
                <field name="total_high_medium"/>
                <field name="total_high"/>
                <field name="total_double_yolk"/>
                <field name="total_broken"/>
                <field name="total_white"/>
                <field name="total_damage"/>
                <field name="total_egg"/>
                <field name="percentage"/>
                <field name="cumulative_egg"/>
                <field name="egg_weight"/>
                <field name="act"/>
            </list>
        </field>
    </record>
    

    <record id="view_farm_production_details_form" model="ir.ui.view">
        <field name="name">farm.production.details.form</field>
        <field name="model">farm.production.details</field>
        <field name="arch" type="xml">
            <form string="Production Details">
                <sheet>
                    <group>
                        <field name="date"/>
                        <field name="flock_id"/>
                        <field name="total_hens" readonly="1"/>
                    </group>

                    <notebook>

                         <page string="Daily Egg Entries">
                            <field name="egg_line_ids">
                                <list string="Egg Lines" editable="bottom">
                                    <field name="date" attrs="{'readonly': [('state', '=', 'done')]}"/>
                                    <field name="egg_type" attrs="{'readonly': [('state', '=', 'done')]}"/>
                                    <field name="value" attrs="{'readonly': [('state', '=', 'done')]}"/>
                                    <field name="short_description" attrs="{'readonly': [('state', '=', 'done')]}"/>
                                    <field name="state" readonly="1"/>
                                    <button name="action_done" type="object" string="Done"
                                            attrs="{'invisible': [('state', '=', 'done')]}"/>
                                </list>
                                <form string="Egg Line">
                                    <sheet>
                                        <group>
                                            <field name="date" attrs="{'readonly': [('state', '=', 'done')]}"/>
                                            <field name="egg_type" attrs="{'readonly': [('state', '=', 'done')]}"/>
                                            <field name="value" attrs="{'readonly': [('state', '=', 'done')]}"/>
                                            <field name="short_description" attrs="{'readonly': [('state', '=', 'done')]}"/>
                                            <field name="state" readonly="1"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>

                        <page string="Daily Totals">
                            <group>
                                <group>
                                    <field name="total_small" readonly="1"/>
                                    <field name="total_medium" readonly="1"/>
                                    <field name="total_high_medium" readonly="1"/>
                                    <field name="total_high" readonly="1"/>
                                </group>
                                <group>
                                    <field name="total_double_yolk" readonly="1"/>
                                    <field name="total_broken" readonly="1"/>
                                    <field name="total_white" readonly="1"/>
                                    <field name="total_damage" readonly="1"/>
                                </group>
                            </group>
                            <group>
                                <field name="total_egg" readonly="1"/>
                                <field name="percentage" readonly="1"/>
                            </group>
                        </page>

                        <page string="Extra Info">
                            <group>
                                <field name="cumulative_egg"/>
                                <field name="egg_weight"/>
                                <field name="act"/>
                            </group>
                        </page>
                    </notebook>

                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    

    <record id="view_farm_egg_line_tree" model="ir.ui.view">
        <field name="name">farm.egg.line.list</field>
        <field name="model">farm.egg.line</field>
        <field name="arch" type="xml">

            <list editable="bottom">
                <field name="date"/>
                <field name="egg_type"/>
                <field name="value"/>
                <field name="short_description"/>
            </list>
        </field>

    </record>

    <record id="view_farm_egg_line_form" model="ir.ui.view">
        <field name="name">farm.egg.line.form</field>
        <field name="model">farm.egg.line</field>
        <field name="arch" type="xml">
            <form string="Egg Line">
                <sheet>
                    <group>
                        <field name="production_id"/>
                        <field name="date"/>
                        <field name="egg_type"/>
                        <field name="value"/>
                        <field name="short_description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    

</odoo>
