<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="action_farm_temperature" model="ir.actions.act_window">
        <field name="name">Temperature Records</field>
        <field name="res_model">farm.temperature</field>
        <field name="view_mode">list,form</field>
    </record>
    
    <menuitem id="menu_farm_temperature_root" name="Temperature" parent="menu_layer_flock_root" action="action_farm_temperature" sequence="40"/>

    <record id="view_farm_temperature_tree" model="ir.ui.view">
        <field name="name">farm.temperature.list</field>
        <field name="model">farm.temperature</field>
        <field name="arch" type="xml">
            <list string="Temperature Records">
                <field name="date"/>
                <field name="time"/>
                <field name="inside_min"/>
                <field name="inside_max"/>
                <field name="outside_min"/>
                <field name="outside_max"/>
            </list>
        </field>
    </record>

    <record id="view_farm_temperature_form" model="ir.ui.view">
        <field name="name">farm.temperature.form</field>
        <field name="model">farm.temperature</field>
        <field name="arch" type="xml">
            <form string="Temperature Record">
                <sheet>
                    <group>
                        <field name="date"/>
                        <field name="time"/>
                        <field name="inside_min"/>
                        <field name="inside_max"/>
                        <field name="outside_min"/>
                        <field name="outside_max"/>
                        <field name="notes"/>
                    </group>
                </sheet>
                <!-- Chatter -->
               <chatter/>
            </form>

        </field>
    </record>
</odoo>
