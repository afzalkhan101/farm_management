<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <menuitem id="menu_layer_flock_root" name="Farm Management" sequence="10"/>
    <menuitem id="menu_layer_flock_config" name="Configuration" parent="menu_layer_flock_root" sequence="10"/>

    <record id="view_layer_flock_list" model="ir.ui.view">
        <field name="name">farm.layer.flock.list</field>
        <field name="model">farm.layer.flock</field>
        <field name="arch" type="xml">
            <list string="Flock List">
                <field name="name"/>
                <field name="bird_type"/>
                <field name="opening_bird_count"/>
                <field name="product_id"/>
            </list>
        </field>
    </record>

    <record id="view_layer_flock_form" model="ir.ui.view">
        <field name="name">farm.layer.flock.form</field>
        <field name="model">farm.layer.flock</field>
        <field name="arch" type="xml">
            <form string="Flock Information">
                <sheet>
                    <group col="2">
                        <group>
                            <field name="name" placeholder="Enter Flock Name"/>
                            <field name="bird_type"/>
                            <field name="product_id"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                        <group>
                            <field name="opening_bird_count"/>
                            <field name="age_in_days"/>
                            <field name="age_display"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="note_html"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_layer_flock_graph" model="ir.ui.view">
        <field name="name">farm.layer.flock.graph</field>
        <field name="model">farm.layer.flock</field>
        <field name="arch" type="xml">
            <graph string="Flock Overview" type="bar">
                <field name="bird_type" type="row"/>
            </graph>
        </field>
    </record>

    <record id="action_layer_flock_dashboard" model="ir.actions.act_window">
        <field name="name">Flocks Dashboard</field>
        <field name="res_model">farm.layer.flock</field>
        <field name="view_mode">list,form,graph</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode':'list','view_id':ref('view_layer_flock_list')}),
            (0, 0, {'view_mode':'form','view_id':ref('view_layer_flock_form')}),
            (0, 0, {'view_mode':'graph','view_id':ref('view_layer_flock_graph')})
        ]"/>
    </record>

    <menuitem id="menu_layer_flock_dashboard" 
              name="Flocks Dashboard" 
              parent="menu_layer_flock_config" 
              action="action_layer_flock_dashboard"/>

</odoo>