<?xml version="1.0" encoding="UTF-8"?>
<odoo>
   

   

    <record id="action_farm_medicine" model="ir.actions.act_window">
        <field name="name">Medicines</field>
        <field name="res_model">farm.medicine</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to create a new medicine record.
            </p>
        </field>
    </record>

    <menuitem id="menu_farm_root" name="Farm Management"/>
    <menuitem id="menu_farm_medicine_root" name="Medicines" parent="menu_layer_flock_root" action="action_farm_medicine"/>

    <record id="view_farm_medicine_list" model="ir.ui.view">
        <field name="name">farm.medicine.list</field>
        <field name="model">farm.medicine</field>
        <field name="arch" type="xml">
            <list string="Medicines">
                <field name="name"/>
                <field name="quantity"/>
                <field name="unit"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="view_farm_medicine_form" model="ir.ui.view">

        <field name="name">farm.medicine.form</field>
        <field name="model">farm.medicine</field>
        <field name="arch" type="xml">
            <form string="Medicine">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="quantity"/>
                        <field name="unit"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
